# name: test/sql/conventions.test
# description: Day-count year fractions, discounting, and convention discovery
# group: [vgi_quant]

require-env VGI_QUANT_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'quant' AS quant (TYPE vgi, LOCATION '${VGI_QUANT_WORKER}');

# 2026-01-01 -> 2026-07-01 is 181 days; ACT/360 = 181/360 ~ 0.5028.
query I
SELECT ROUND(quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'ACT/360'), 4);
----
0.5028

# Same span under 30/360 is exactly half a year.
query I
SELECT ROUND(quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', '30/360'), 4);
----
0.5

# Convention strings are case-insensitive.
query I
SELECT quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'act/360')
     = quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'ACT/360');
----
true

# NULL date -> NULL output.
query I
SELECT quant.year_fraction(NULL, DATE '2026-07-01', 'ACT/360') IS NULL;
----
true

# Discounting helpers.
query I
SELECT ROUND(quant.discount_factor(0.05, 1), 4);
----
0.9512

query I
SELECT ROUND(quant.present_value(100, 0.05, 1), 3);
----
95.123

# ---- day_count_conventions() discovery ----

query I
SELECT count(*) > 0 FROM quant.day_count_conventions();
----
true

# The discovery list contains the conventions year_fraction accepts (the
# convention argument must be a constant, so each is exercised directly above /
# below rather than cross-joined).
query I rowsort
SELECT name FROM quant.day_count_conventions();
----
30/360
ACT/360
ACT/365
ACT/ACT

# Each listed convention is a valid year_fraction argument (non-NULL result).
query I
SELECT quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'ACT/365') IS NOT NULL
   AND quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'ACT/ACT') IS NOT NULL;
----
true

# An unknown convention raises a clear error.
statement error
SELECT quant.year_fraction(DATE '2026-01-01', DATE '2026-07-01', 'NOPE/999');
----

statement ok
DETACH quant;
